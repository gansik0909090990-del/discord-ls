# Google Apps Script Script Properties
SPREADSHEET_ID=put_google_spreadsheet_id_here
DEFAULT_ADMIN_LOGIN=Gans
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BOT_TOKEN=put_discord_bot_token_here
DISCORD_DM_PROXY_URL=https://your-worker.your-subdomain.workers.dev
DISCORD_DM_PROXY_SECRET=put_same_value_as_worker_secret_here

# Cloudflare Worker environment variables
WORKER_SECRET=put_long_random_secret_here
DISCORD_BOT_TOKEN=put_discord_bot_token_here

# Notes
# Do not commit real secrets.
# Keep DISCORD_BOT_TOKEN only in Script Properties and Cloudflare variables.
# The Worker must not accept bot tokens from request headers.
